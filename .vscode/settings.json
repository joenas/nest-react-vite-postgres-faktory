{
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "eslint.validate": [
    "javascript",
    "javascriptreact",
    "typescript",
    "typescriptreact"
  ],
  "eslint.format.enable": true,
  "files.insertFinalNewline": true,
  "rest-client.environmentVariables": {
    "development": {
      "host": "http://localhost:4002",
    }
  },
  "files.associations": {
    "*.http": "http",
    "*.rest": "http"
  }
}
