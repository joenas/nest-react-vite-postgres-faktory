{
  "name": "nest-react-vite-postgres-faktory",
  "version": "1.0.0",
  "description": "NestJS API boilerplate",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "build": "nest build",
    "build:frontend": "cd frontend && npm install && npm run build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:dev:frontend": "cd frontend && npm run dev",
    "start:debug": "nest start --debug --watch",
    "format": "prettier --write \"src/**/*.ts\" \"frontend/**/*.ts\"",
    "lint": "eslint \"{src,frontend}/**/*.ts\" --fix",
    "api:generate": "cd frontend && npm run generate-api",
    "cli": "ts-node -r tsconfig-paths/register",
    "db:migrate": "sequelize-cli db:migrate",
    "db:migrate:undo": "sequelize-cli db:migrate:undo"
  },
  "dependencies": {
    "@nestjs/common": "^10.3.0",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.3.0",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^10.3.0",
    "@nestjs/schedule": "^6.1.0",
    "@nestjs/sequelize": "^10.0.1",
    "@nestjs/swagger": "^7.1.17",
    "@sentry/node": "^10.32.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "cookie-parser": "^1.4.6",
    "faktory-worker": "^4.7.1",
    "influx": "^5.11.0",
    "joi": "^17.11.0",
    "jsdom": "^27.3.0",
    "node-fetch": "^3.3.2",
    "openai": "^6.15.0",
    "openid-client": "^6.8.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.11.3",
    "rxjs": "^7.8.1",
    "sanitize-html": "^2.17.0",
    "sequelize": "^6.35.2",
    "sequelize-cli": "^6.6.3",
    "sequelize-typescript": "^2.1.5"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.2.1",
    "@nestjs/schematics": "^10.0.3",
    "@nestjs/testing": "^10.3.0",
    "@types/cookie-parser": "^1.4.6",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^20.10.6",
    "@types/passport-jwt": "^4.0.1",
    "@types/sanitize-html": "^2.16.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.2",
    "jest": "^29.7.0",
    "prettier": "^3.1.1",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.1.1",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  }
}
